POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=onenote_mcp

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

APP_SESSION_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
MICROSOFT_SCOPES=email User.Read Notes.Read
FRONTEND_ORIGIN=http://localhost:5173
MCP_SERVER_URL=http://localhost:8000/mcp/

# Google Cloud Vision (OCR)
GOOGLE_CLOUD_VISION_API_KEY=

# Drain the sync-job queue inside the API process so a UI sync starts right away (no separate
# `python -m sync.worker`). Only safe for single-process local dev — do NOT combine with the
# standalone worker or cron, and keep it False in multi-replica/production. See
# plans/sync-rate-limit-fix-plan.md (single-executor invariant).
SYNC_WORKER_IN_PROCESS=false

# WorkOS AuthKit — OAuth 2.1 front for web MCP connectors (claude.ai / ChatGPT).
# Leave blank for local dev / CLI-only: the MCP server then accepts the onmcp_
# bearer path alone. WORKOS_AUTHKIT_DOMAIN is the issuer (JWKS + AS metadata are
# discovered from it); a bare host like "your-env.authkit.app" is fine — the
# https:// scheme is added automatically. See plans/mcp-oauth-web-clients.md.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_AUTHKIT_DOMAIN=
